[Unit]
Description=rag-mcp RAG MCP Server
After=network.target

[Service]
WorkingDirectory=%h/projects/rag-mcp
ExecStart=%h/projects/rag-mcp/.venv/bin/rag-mcp serve
Environment=PORT=8004
Environment=RAG_DISTILL_MODEL=Qwen3.6-35b-1M-P1-MTP-NGRAM
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
